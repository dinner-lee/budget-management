# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="change-this-to-a-random-secret-string"
NEXTAUTH_URL="http://localhost:3000"

# ── Synology NAS ────────────────────────────────────────────
# 파일 업로드: 파일요청 링크 (인증 불필요)
NAS_FILE_REQUEST_URL="https://lsri-admin.tw4.quickconnect.to/sharing/lPkoPufAv"

# 파일 다운로드: 관리자 계정 (관리자 전용 다운로드 API에 사용)
NAS_HOST="https://lsri-admin.tw4.quickconnect.to"
NAS_USER="admin"
NAS_PASS="your-nas-password"

# 파일요청이 저장되는 NAS 폴더 경로 (NAS 관리자 > 파일요청에서 확인)
# 예: /FileRequest/budget-evidence
NAS_UPLOAD_PATH="/FileRequest/budget-evidence"
